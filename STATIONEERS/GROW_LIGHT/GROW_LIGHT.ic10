# Default to ON on every IC boot before entering the timed cycle.
sbn HASH("StructureGrowLight") HASH("Grow Light") On 1   # Turn lights ON

start:
sleep 840                            # 14 minutes (840 seconds)
sbn HASH("StructureGrowLight") HASH("Grow Light") On 0   # Turn lights OFF
sleep 360                            # 6 minutes (360 seconds)
sbn HASH("StructureGrowLight") HASH("Grow Light") On 1   # Turn lights ON
j start
