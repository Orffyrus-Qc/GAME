# Rotates a landing pad selector through up to 4 pads.
alias Pad d9
alias Resume d1
alias Reset d2
alias Status d5
alias PadNum r0
alias T r1

start:
move PadNum 0

main:
yield
l T Pad On
bgt T 0 main
add PadNum PadNum 1
blt PadNum 4 write_pad
move PadNum 0

write_pad:
s Pad Setting PadNum
l T Resume On
bgt T 0 reset_pad
l T Reset On
bgt T 0 reset_pad
s Status Setting 6
sleep 2
j main

reset_pad:
move PadNum 0
s Resume On 0
s Reset On 0
j main
